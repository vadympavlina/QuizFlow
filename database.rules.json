{
  "rules": {
    "users": {
      ".read": true,
      "$userId": {
        ".write": "data.child('login').val() === newData.child('login').val() || !data.exists()",
        "aiSettings": {
          ".read": true,
          ".write": true
        }
      }
    },
    "settings": {
      ".read": true,
      "ai": {
        ".read": true,
        ".write": true
      }
    },
    "teachers": {
      "$teacherId": {
        "tests": {
          ".read": true,
          ".write": true,
          ".indexOn": ["folderId","status"]
        },
        "links": {
          ".read": true,
          ".write": true,
          ".indexOn": ["testId","status"]
        },
        "attempts": {
          ".read": true,
          ".write": true,
          ".indexOn": ["testId","linkId","status"]
        },
        "folders": {
          ".read": true,
          ".write": true
        },
        "students": {
          ".read": true,
          ".write": true
        },
        "notifications": {
          ".read": true,
          ".write": true
        },
        "meta": {
          ".read": true,
          ".write": true
        }
      }
    }
  }
}
